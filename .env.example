# 火山方舟 Responses API 配置
LLM_API_TYPE=ark_responses
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/responses
ARK_API_KEY=your_ark_api_key_here
ARK_MODEL=deepseek-v4-flash-260425

# 通用参数
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.3

# Supabase 文档元数据存储
USE_SUPABASE_DOC_STORE=false
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_anon_key
SUPABASE_DOCUMENTS_TABLE=documents
